<!DOCTYPE html>
<html>
<head>
<title>QR Code Scanner</title>

<style>

body{
font-family: Arial;
text-align:center;
background:linear-gradient(135deg,#4facfe,#00f2fe);
margin:0;
padding:0;
}

.container{
background:white;
width:400px;
margin:auto;
margin-top:50px;
padding:20px;
border-radius:10px;
box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

#reader{
width:100%;
margin-top:15px;
}

#result{
margin-top:20px;
font-size:18px;
word-wrap:break-word;
}

button{
margin-top:10px;
padding:10px 15px;
border:none;
border-radius:6px;
background:#28a745;
color:white;
cursor:pointer;
}

button:hover{
background:#218838;
}

</style>
</head>

<body>

<div class="container">

<h2>QR Code Scanner</h2>

<div id="reader"></div>

<div id="result">Scan a QR code</div>

<button onclick="openLink()">Open Link</button>

</div>

<!-- QR Scanner Library -->
<script src="https://unpkg.com/html5-qrcode"></script>

<script>

let scannedData="";

function onScanSuccess(decodedText){

scannedData=decodedText;

document.getElementById("result").innerHTML=
"Scanned Result: <br>"+decodedText;

}

let html5QrCode = new Html5QrcodeScanner(
"reader",
{ fps: 10, qrbox: 250 }
);

html5QrCode.render(onScanSuccess);

function openLink(){

if(scannedData.startsWith("http")){
window.open(scannedData,"_blank");
}
else{
alert("Scanned data is not a link:\n"+scannedData);
}

}

</script>

</body>
</html>
